NODE_ENV=development
PORT=3001

# API Gateway
GATEWAY_PORT=8080
AUTH_SERVICE_URL="http://localhost:3001"
STUDENT_SERVICE_URL="http://localhost:3002"
COURSE_SERVICE_URL="http://localhost:3003"
NOTIFICATION_SERVICE_URL="http://localhost:3004"

# Prisma / MySQL
DATABASE_URL="mysql://root:Lalartsetseg%21%40%231234@localhost:3306/microservice_db"

# JWT
JWT_ACCESS_SECRET="dev_access_secret_please_change_123456"
JWT_REFRESH_SECRET="dev_refresh_secret_please_change_123456"
JWT_ISSUER="school-platform"
JWT_AUDIENCE="school-platform-api"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# Dev convenience: seed initial admin (Docker compose default)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="Admin123!"

# CORS
CORS_ORIGIN="http://localhost:3000"

# Redis
REDIS_URL="redis://localhost:6379"
CACHE_TTL_SECONDS=60
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120

# RabbitMQ
RABBITMQ_URL="amqp://guest:guest@localhost:5672"
RABBITMQ_EXCHANGE="school.events"
RABBITMQ_PREFETCH=10
RABBITMQ_MAX_RETRIES=5
RABBITMQ_RETRY_BASE_DELAY_MS=1000
NOTIFICATION_WORKER_ENABLED=true
NOTIFICATION_MAX_ITEMS=200

# Swagger
SWAGGER_TITLE="Microservice Template API"
SWAGGER_VERSION="1.0.0"

# Monitoring
ENABLE_METRICS=false
METRICS_PATH="/metrics"
